{"version":"0.3.0","body":"/**\n * ADVANCED ASSET LOGGING SCRIPT\n * Handles Assign (New ID) and Return (Auto-fetch Previous User)\n */\nasync function main(workbook: ExcelScript.Workbook) {\n  // --- CONFIGURATION ---\n  const LOG_SHEET_NAME = \"Asset Log Entry\";\n  const MASTER_TABLE_NAME = \"MasterTable\"; // Check your table name\n  const HISTORY_TABLE_NAME = \"Assignment_Log\"; // Or \"Log History\" - check your file\n  const EMP_TABLE_NAME = \"tbl_Employees\";\n\n  // --- 1. SETUP & CHECKS ---\n  const logSheet = workbook.getWorksheet(LOG_SHEET_NAME);\n  const masterTable = workbook.getTable(MASTER_TABLE_NAME) || workbook.getTable(\"MasterTable\");\n  const logTable = workbook.getTable(HISTORY_TABLE_NAME) || workbook.getTable(\"Log History\");\n  const empTable = workbook.getTable(EMP_TABLE_NAME) || workbook.getTable(\"Employees\");\n\n  if (!logSheet || !masterTable || !logTable || !empTable) {\n    console.log(\"Critical Error: Missing Tables or Sheet.\");\n    return;\n  }\n\n  // --- 2. READ FORM INPUTS ---\n  // Using Named Ranges or Direct Addresses based on your template\n  const assetID = logSheet.getRange(\"C5\").getText().trim();\n  const action = logSheet.getRange(\"C6\").getText().trim(); // \"Assign\" or \"Return\"\n  const newStatus = logSheet.getRange(\"C7\").getText().trim(); // e.g. \"Active\"\n  const condition = logSheet.getRange(\"C8\").getText().trim();\n  // C9 is typically \"Return From\" - we will Auto-Fill this if empty\n  let returnFromInput = logSheet.getRange(\"C9\").getText().trim();\n  const assignedToInput = logSheet.getRange(\"C10\").getText().trim(); // Dropdown for Employee\n  const notes = logSheet.getRange(\"C11\").getText();\n  const statusMsg = logSheet.getRange(\"B12\");\n\n  if (!assetID || !action) {\n    statusMsg.setValue(\"Error: Asset ID and Action are required.\");\n    return;\n  }\n\n  // --- 3. FIND ASSET IN MASTER TABLE ---\n  const masterRange = masterTable.getRangeBetweenHeaderAndTotal();\n  const masterValues = masterRange.getValues();\n  const headers = masterTable.getHeaderRowRange().getValues()[0] as string[];\n\n  // Map Master Columns\n  const c = {\n    AssetID: headers.indexOf(\"AssetID\"),\n    Username: headers.indexOf(\"Username\"),\n    Status: headers.indexOf(\"Status\"),\n    Condition: headers.indexOf(\"Condition\"),\n    Brand: headers.indexOf(\"Brand\"),\n    Model: headers.indexOf(\"Model\"),\n    EmpID: headers.indexOf(\"EmployeeID\"),\n    EmpDisp: headers.indexOf(\"EmployeeDisplay\"),\n    AssignID: headers.indexOf(\"AssignmentID\"),\n    AssignDisp: headers.indexOf(\"AssignmentDisplay\"),\n    DateAssigned: headers.indexOf(\"DateAssigned\")\n  };\n\n  // Find the Row Index\n  let rowIndex = -1;\n  for (let i = 0; i < masterValues.length; i++) {\n    if (String(masterValues[i][c.AssetID]).trim().toUpperCase() === assetID.toUpperCase()) {\n      rowIndex = i;\n      break;\n    }\n  }\n\n  if (rowIndex === -1) {\n    statusMsg.setValue(\"Error: Asset ID not found in MasterTable.\");\n    return;\n  }\n\n  const row = masterValues[rowIndex];\n  const currentOwner = String(row[c.Username]); // Existing user before change\n\n  // --- 4. ACTION LOGIC ---\n  const timestamp = new Date().toISOString();\n\n  if (action === \"Return\") {\n    // === AUTO FETCH RETURN FROM ===\n    // If user didn't type who returned it, we assume the Current Owner returned it.\n    if (!returnFromInput || returnFromInput === \"\") {\n      returnFromInput = currentOwner;\n    }\n\n    // Reset Master Data\n    row[c.Status] = \"In Stock\";\n    row[c.Condition] = condition || row[c.Condition];\n    row[c.Username] = \"Not Assigned\";\n    row[c.EmpID] = \"\";\n    row[c.EmpDisp] = \"\";\n    row[c.AssignID] = \"\"; // Clear Assignment ID\n    row[c.AssignDisp] = \"\";\n    row[c.DateAssigned] = \"\";\n\n  } else if (action === \"Assign\") {\n    // === ASSIGN LOGIC ===\n    \n    // 1. Get Employee Details\n    const empValues = empTable.getRangeBetweenHeaderAndTotal().getValues();\n    const empHeaders = empTable.getHeaderRowRange().getValues()[0] as string[];\n    const e_Email = empHeaders.indexOf(\"Email\");\n    const e_ID = empHeaders.indexOf(\"EmployeeID\");\n    const e_Display = empHeaders.indexOf(\"EmployeeDisplay\");\n\n    const emp = empValues.find(r => \n      String(r[e_Email]).toLowerCase() === assignedToInput.toLowerCase() ||\n      String(r[e_Display]).toLowerCase() === assignedToInput.toLowerCase()\n    );\n\n    if (!emp) {\n      statusMsg.setValue(\"Error: Selected Employee not found in Employee Table.\");\n      return;\n    }\n\n    // 2. Generate New Assignment ID\n    // Logic: AS + Random 5 digits (Simple & Robust)\n    const newAssignID = \"AS-\" + Math.floor(10000 + Math.random() * 90000);\n\n    // 3. Update Master Row\n    row[c.Status] = \"Active\";\n    row[c.Condition] = condition || row[c.Condition];\n    row[c.Username] = String(emp[e_Email]);\n    row[c.EmpID] = emp[e_ID];\n    row[c.EmpDisp] = emp[e_Display];\n    row[c.AssignID] = newAssignID;\n    \n    const model = row[c.Model] || \"Asset\";\n    row[c.AssignDisp] = `${newAssignID} - ${emp[e_Display]} - ${model}`;\n    row[c.DateAssigned] = timestamp;\n  }\n\n  // --- 5. WRITE UPDATES TO MASTER TABLE ---\n  masterTable.getRangeBetweenHeaderAndTotal().getRow(rowIndex).setValues([row]);\n\n  // --- 6. WRITE TO LOG HISTORY ---\n  // Generate Log ID\n  const logID = \"LOG-\" + Math.floor(100000 + Math.random() * 900000);\n\n  // Add Row to Log Table\n  // Schema: LogID, Date, Model, Brand, AssetID, Action, Status, Condition, ReturnFrom, AssignedTo, Notes\n  logTable.addRow(null, [\n    logID,\n    timestamp,\n    row[c.Model],\n    row[c.Brand],\n    assetID,\n    action,\n    row[c.Status], // Resulting Status\n    condition,\n    returnFromInput, // The \"Return From\" (Auto-fetched or Manual)\n    (action === \"Assign\") ? String(row[c.Username]) : \"Not Assigned\",\n    notes\n  ]);\n\n  // --- 7. CLEANUP FORM ---\n  statusMsg.setValue(`Success: ${action} completed for ${assetID}.`);\n  statusMsg.getFormat().getFont().setColor(\"Green\");\n\n  // Clear inputs but keep some defaults if needed\n  logSheet.getRange(\"C5\").clear(ExcelScript.ClearApplyTo.contents); // ID\n  logSheet.getRange(\"C6\").clear(ExcelScript.ClearApplyTo.contents); // Status\n  logSheet.getRange(\"C7\").clear(ExcelScript.ClearApplyTo.contents); // Condition\n  logSheet.getRange(\"C8\").clear(ExcelScript.ClearApplyTo.contents); // Condition\n  logSheet.getRange(\"C9\").clear(ExcelScript.ClearApplyTo.contents); // Return From\n  logSheet.getRange(\"C10\").clear(ExcelScript.ClearApplyTo.contents); // Assigned To\n  logSheet.getRange(\"C11\").clear(ExcelScript.ClearApplyTo.contents); // Notes\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"ADVANCED ASSET LOGGING SCRIPT\\nHandles Assign (New ID) and Return (Auto-fetch Previous User)\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}